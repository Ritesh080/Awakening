# Copy to .env and fill in. With no Stripe keys set, billing runs in a safe
# demo/test mode so the full flow works locally without charging anyone.

# Server
API_PORT=4000
CLIENT_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-string

# Stripe (https://dashboard.stripe.com/apikeys) — leave blank for demo mode
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs from your Stripe dashboard (Products → Pricing)
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
